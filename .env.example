# Скопируй этот файл в .env и впиши реальные значения.
# .env в .gitignore — НЕ коммить его. Этот .env.example — можно.

# === DataForSEO (живой SERP, объёмы, бэклинки) ===
DATAFORSEO_LOGIN=your_login
DATAFORSEO_PASSWORD=your_password

# === Google (один service-account JSON на GSC + GA4) ===
# Путь к JSON-ключу. Держи файл ВНЕ репозитория (напр. ~/.secrets/).
GOOGLE_APPLICATION_CREDENTIALS=/Users/you/.secrets/bixbit-service-account.json
GSC_SITE_URL=https://bixbit.io/
GA4_PROPERTY_ID=000000000

# === Google PageSpeed / CrUX (Core Web Vitals) ===
PAGESPEED_API_KEY=your_key

# === Бэклинки (бесплатные тиры) ===
MOZ_ACCESS_ID=your_id
MOZ_SECRET_KEY=your_secret
BING_WEBMASTER_API_KEY=your_key
